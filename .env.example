APP_NAME="Odoo Integration"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# API Security - Generate a secure random string
API_KEY=your-secure-api-key-here

# Odoo Connection Settings
# Get these from your Odoo trial instance at odoo.com
ODOO_URL=https://your-instance.odoo.com
ODOO_DB=your-instance-name
ODOO_USERNAME=your-email@example.com
ODOO_API_KEY=your-odoo-api-key

# Database (optional - not required for basic ERP integration)
DB_CONNECTION=sqlite
DB_DATABASE=:memory:
